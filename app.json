{
  "expo": {
    "name": "Qitlo",
    "slug": "qitlo-mobile",
    "version": "1.0.0",
    "scheme": "qitlo",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e1620"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.qitlo.mobile"
    },
    "android": {
      "package": "com.qitlo.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e1620"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Qitlo uses your photos so you can set a profile picture."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Qitlo uses Face ID to unlock your encrypted data on this device."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
