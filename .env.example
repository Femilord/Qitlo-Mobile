# Copy this file to .env (which is gitignored) and adjust as needed.
#
# Set this to the base URL of your Qitlo backend. The mobile app calls
# /api/auth/signup, /api/auth/login, /api/auth/me, /api/auth/logout, and
# /api/sync against this base.
#
# For local development against `npm run dev` in the webapp:
#   EXPO_PUBLIC_API_URL=http://localhost:3000
# (iOS Simulator pointing at localhost works as-is on macOS. Physical
# device on the same WiFi uses your Mac's LAN IP, e.g. http://192.168.1.x:3000.)
#
# For the deployed Vercel backend:
#   EXPO_PUBLIC_API_URL=https://<your-vercel-domain>
EXPO_PUBLIC_API_URL=https://qitlo-project-hnb4o3iwu-femilord-7506s-projects.vercel.app
